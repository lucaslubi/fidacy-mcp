{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.fidacy/mcp",
  "description": "Payment firewall for AI agents: a signed, verifiable verdict on every money-moving action.",
  "repository": { "url": "https://github.com/lucaslubi/fidacy-mcp", "source": "github" },
  "version": "0.1.9",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@fidacy/mcp",
      "version": "0.1.9",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        { "name": "FIDACY_ENGINE_API_KEY", "description": "Optional: enables signed trust verdicts (assess_action).", "isRequired": false, "isSecret": true },
        { "name": "FIDACY_MODE", "description": "Optional: 'http' for the hosted paid core.", "isRequired": false }
      ]
    }
  ]
}
